generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model User {
  id             String   @id
  name           String
  email          String
  emailVerified  Boolean  @default(false)
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  bio            String?
  githubUsername String?
  karmaPoints    Int      @default(0)
  location       String?
  position       String?
  techStack      String[]
  username       String   @unique

  sessions Session[]
  accounts Account[]

  organizedHackathons Hackathon[]            @relation("UserHackathons")
  ownedTeams          Team[]                 @relation("UserTeams")
  teamMemberships     TeamMember[]
  teamApplications    TeamApplication[]
  participations      HackathonParticipant[]

  role Role @default(USER)

  @@unique([email])
  @@map("user")
}

enum Role {
  USER
  ADMIN
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id         String @id
  accountId  String
  providerId String
  userId     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum HackathonStatus {
  DRAFT
  UPCOMING
  LIVE
  ENDED
  CANCELLED
}

model Hackathon {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String
  image       String?

  startDate DateTime
  endDate   DateTime

  location     String
  locationMode String   @default("in_person") // "remote" | "in_person" | "hybrid"
  isOnline     Boolean  @default(false)
  tags         String[]
  techs        String[]

  requiresApproval Boolean @default(false)
  maxParticipants  Int?
  maxTeamSize      Int

  themeBg       String?
  themeGradient String?
  themeStyle    String? // "default" | "neon" | "minimal" | "cyber"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizerId String
  organizer   User   @relation("UserHackathons", fields: [organizerId], references: [id])

  teams        Team[]
  participants HackathonParticipant[]
  sponsors     HackathonSponsor[]
  prizes       HackathonPrize[]

  status HackathonStatus @default(DRAFT)

  source       String?   // "luma", "manual"
  externalId   String?   // ID or slug from Luma
  externalUrl  String?   // Original URL (lu.ma/...)
  lastSyncedAt DateTime? // Last sync timestamp
  isReadOnly   Boolean   @default(false)

  @@index([organizerId])
  @@index([startDate])
  @@index([location])
  @@index([source])
  @@index([externalId])
  @@index([externalUrl])
  @@map("hackathon")
}

model HackathonParticipant {
  id String @id @default(cuid())

  userId      String
  hackathonId String

  status ParticipantStatus @default(PENDING)

  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId])
  @@index([hackathonId])
}

enum ParticipantStatus {
  PENDING
  APPROVED
  REJECTED
}

model Team {
  id          String  @id @default(cuid())
  name        String
  description String?

  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("UserTeams", fields: [ownerId], references: [id])

  maxMembers Int
  techs      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      TeamMember[]
  applications TeamApplication[]
  questions    TeamQuestion[]

  @@index([hackathonId])
  @@index([ownerId])
}

model TeamMember {
  id String @id @default(cuid())

  teamId String
  userId String

  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([userId])
}

model TeamApplication {
  id String @id @default(cuid())

  teamId String
  userId String

  status  ApplicationStatus @default(PENDING)
  message String?
  rejectionReason String?

  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  answers TeamApplicationAnswer[]

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model TeamQuestion {
  id String @id @default(cuid())

  teamId   String
  question String

  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])

  answers TeamApplicationAnswer[]

  @@index([teamId])
}

model TeamApplicationAnswer {
  id String @id @default(cuid())

  applicationId String
  questionId    String

  answer String

  application TeamApplication @relation(fields: [applicationId], references: [id])
  question    TeamQuestion    @relation(fields: [questionId], references: [id])

  @@index([applicationId])
  @@index([questionId])
}

model Sponsor {
  id          String  @id @default(cuid())
  name        String
  url         String
  logo        String?
  description String?
  tier        Tier

  createdAt DateTime @default(now())

  hackathons HackathonSponsor[]
}

enum Tier {
  PLATINUM
  GOLD
  SILVER
  BRONZE
}

model HackathonSponsor {
  id String @id @default(cuid())

  hackathonId String
  sponsorId   String

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  sponsor   Sponsor   @relation(fields: [sponsorId], references: [id])

  @@unique([hackathonId, sponsorId])
  @@index([sponsorId])
}

model HackathonPrize {
  id          String    @id @default(cuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  place       String // "1st", "2nd", "Track Winner"
  amount      Int // "$10,000"
  description String // "Grand Prize"
  sortOrder   Int       @default(0)

  @@index([hackathonId])
  @@map("hackathon_prize")
}
